# International Conference Widget
flowcontainer = {
	name = "widget_com_international_conference"
	ignoreinvisible = yes

	flowcontainer = {
		direction = vertical
		spacing = 10

		com_international_organization_header = {
			blockoverride "spacer_size" {
				size = { 540 120 }
			}
		}
		com_international_organization_panel = {
			blockoverride "interorg_journal_icon" {
				icon = {
					parentanchor = top|hcenter
					position = { 0 -140 }
					size = { 520 140 }
					texture = "gfx/interface/backgrounds/com_conference_frame_top.dds"
					icon = {
						parentanchor = center
						texture = "[JournalEntry.GetIcon]"
						position = { 0 5 }
						size = { 100 100 }
					}
				}
			}

			blockoverride "interorg_backdrop_texture" {
				texture = "gfx/interface/character_panel/backgrounds/char_role_politician.dds"
			}
			blockoverride "interorg_icon_frame_texture" {
				texture = "gfx/coat_of_arms/textured_emblems/pb_frame_03.dds"
			}
		}
		com_international_organization_reason = { }
		com_international_organization_buttons = { }
		com_international_organization_modifiers = { }
		com_international_organization_members = {
			blockoverride "com_members_header" {
				default_header_clean_faded = {
					parentanchor = hcenter
					blockoverride "text" {
						text = "com_gui_interorg_participants_header"
					}
					blockoverride "size" {
						size = { 532 45 }
					}
				}
			}
		}
	}
}


####---------- INTERNATIONAL ORGANIZATION GUI TYPES ----------####
types com_international_organization_types {

	type com_international_organization_header = widget {
		block "spacer_size" {
			size = { 540 30 }
		}
	}

	type com_international_organization_panel = widget {
		# FRAME SIZE
		size = { 530 300 }
		parentanchor = hcenter
		using = Animation_Character_Panel_Refresh

		# BACKGROUND
		block "interorg_background" {
			background = {
				block "interorg_backdrop_texture" {
					texture = "gfx/interface/character_panel/backgrounds/char_role_politician.dds"
				}
				fittype = centercrop
				using = frame_small_mask
			}
		}

		### ORGANIZATION LEADER
		character_portrait_base_no_mask = {
			parentanchor = left|vcenter
			ignore_in_debug_draw = yes
			size = { 340 340 }
			max_update_rate = 24

			visible = "[ComJournalVar('com_interorg_leader_character_var').IsSet]"
			datacontext = "[ComJournalVar('com_interorg_leader_character_var').GetCharacter]"

			block "character_layout" {
				position = { -54 -16 }
			}
			blockoverride "portrait_size" {
				block "character_portrait_size" {
					size = { 340 340 }
				}
			}
			blockoverride "portrait_texture" {
				datacontext = "[ComJournalVar('com_interorg_leader_character_var')]"
				portrait_texture = "[Scope.GetCharacter.GetAnimatedPortrait(
					'ruler_environment',
					'camera_body',
					'idle',
					GetPortraitRenderSize(PdxGuiWidget.Self))
				]"
			}
			blockoverride "portrait_icons" { }
			blockoverride "tooltip" { }
		}

		flowcontainer = {
			direction = vertical
			parentanchor = bottom|left
			position = { 5 -20 }
			spacing = 5
			margin = { 5 5 }
			margin_left = 10

			visible = "[ComJournalVar('com_interorg_leader_character_var').IsSet]"
			datacontext = "[ComJournalVar('com_interorg_leader_character_var').GetCharacter]"

			background = {
				using = dark_area
				alpha = 0.75

				modify_texture = {
					texture = "gfx/interface/masks/fade_horizontal_right.dds"
					blend_mode = alphamultiply
				}
			}

			flowcontainer = {
				direction = horizontal
				spacing = 5

				icon = {
					size = { 35 35 }
					parentanchor = vcenter
					block "interorg_leader_icon" {
						visible = no
						texture = "gfx/interface/icons/alert_icons/formable_possible.dds"
					}
				}

				flowcontainer = {
					direction = vertical

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 200 18 }
						block "interorg_leader_title" {
							text = "com_gui_interorg_character_header"
						}
						align = left|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 200 20 }
						block "interorg_leader_name" {
							text = "com_gui_interorg_character_name"
						}
						align = left|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}
			}

		}

		# TOP/BOTTOM FADE
		icon = {
			using = dark_area
			parentanchor = top|hcenter
			size = { 100% 15% }
			alpha = 0.65
			position = { 0 2 }

			modify_texture = {
				texture = "gfx/interface/masks/fade_vertical_bottom.dds"
				spriteType = Corneredstretched
				spriteborder = { 0 0 }
				blend_mode = alphamultiply
			}
		}
		icon = {
			using = dark_area
			parentanchor = bottom|hcenter
			size = { 100% 12% }
			alpha = 0.65
			position = { 0 2 }

			modify_texture = {
				texture = "gfx/interface/masks/fade_vertical_top.dds"
				spriteType = Corneredstretched
				spriteborder = { 0 0 }
				blend_mode = alphamultiply
			}
		}

		com_organizations_panel_button = {
			parentanchor = top|left
			position = { 20 20 }
		}

		# FRAME
		widget = {
			size = { 100% 100% }
			background = {
				texture = "gfx/interface/character_panel/char_bg_frame.dds"
				margin_left = 18
				margin_right = 12
				margin_bottom = 10
				spriteType = Corneredtiled

				spriteborder_left = 200
				spriteborder_right = 60
				spriteborder_top = 170
				spriteborder_bottom = 180

				texture_density = 2
			}
		}

		## JOURNAL ICON
		block "interorg_journal_icon" {
			widget = {
				parentanchor = top|hcenter
				size = { 150 150 }
				position = { 0 -50 }
				icon = {
					parentanchor = center
					size = { 150 150 }
					position = { 2 2 }
					texture = "gfx/interface/backgrounds/com_bg_pb_frame.dds"
				}
				icon = {
					parentanchor = center
					size = { 150 150 }
					block "interorg_icon_frame_texture" {
						texture = "gfx/coat_of_arms/textured_emblems/pb_frame_04.dds"
					}
				}
				icon = {
					parentanchor = center
					texture = "[JournalEntry.GetIcon]"
					block "journal_icon_position" {
						position = { 0 -10 }
					}
					block "journal_icon_size" {
						size = { 75 75 }
					}
				}
			}
		}

		com_international_organization_details = { }
	}

	type com_international_organization_details = flowcontainer {
		parentanchor = right|vcenter
		position = { -8 5 }
		direction = vertical
		spacing = 5
		margin_right = 5

		background = {
			using = dark_area
			alpha = 0.75

			modify_texture = {
				texture = "gfx/interface/masks/fade_horizontal_left_full.dds"
				blend_mode = alphamultiply
			}
		}

		### LEADER/HOST COUNTRY
		widget = {
			size = { 200 50 }

			block "interorg_detail_1_visibility" {
				visible = "[ComJournalVar('com_interorg_leader_country_var').IsSet]"
			}

			divider_clean = {
				parentanchor = bottom
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				spacing = 7

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 0 5 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 16 }
						block "interorg_detail_1_name" {
							text = "com_gui_interorg_leader_header"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 20 }
						block "interorg_detail_1_content" {
							text = "com_gui_interorg_leader_name"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}

				icon = {
					size = { 35 35 }
					block "interorg_detail_1_texture" {
						texture = "gfx/interface/icons/alert_icons/formable_possible.dds"
					}
				}
			}
		}

		## HEADQUARTERS LOCATION
		widget = {
			size = { 200 50 }

			block "interorg_detail_2_visibility" {
				visible = "[ComJournalVar('com_interorg_headquarters_var').IsSet]"
			}

			divider_clean = {
				parentanchor = bottom
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				spacing = 7

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 0 5 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 16 }
						block "interorg_detail_2_name" {
							text = "com_gui_interorg_headquaters_header"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 20 }
						block "interorg_detail_2_content" {
							text = "com_gui_interorg_headquaters_name"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}

				icon = {
					size = { 35 35 }
					block "interorg_detail_2_texture" {
						texture = "gfx/interface/icons/generic_icons/most_senior_front_commander.dds"
					}
				}
			}
		}

		### NUMBER OF PARTICIPANTS
		widget = {
			size = { 200 50 }

			block "interorg_detail_3_visibility" {
				visible = "[DataModelHasItems(JournalEntry.GetInvolvedCountries)]"
			}

			divider_clean = {
				parentanchor = bottom
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				spacing = 7

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 0 5 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 16 }
						block "interorg_detail_3_name" {
							text = "com_gui_interorg_participants_header"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 20 }
						block "interorg_detail_3_content" {
							text = "[GetDataModelSize(JournalEntry.GetInvolvedCountries)]"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}

				icon = {
					size = { 35 35 }
					block "interorg_detail_3_texture" {
						texture = "gfx/interface/icons/generic_icons/number_of_countries.dds"
					}
				}
			}
		}

		### DETAIL ENTRY 4
		widget = {
			size = { 200 50 }

			block "interorg_detail_4_visibility" {
				visible = "no"
			}

			divider_clean = {
				parentanchor = bottom
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				spacing = 7

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 0 5 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 16 }
						block "interorg_detail_4_name" {
							raw_text = "#todo interorg_detail_4_name#!"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 20 }
						block "interorg_detail_3_content" {
							raw_text = "#todo interorg_detail_4_content#!"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}

				icon = {
					size = { 35 35 }
					block "interorg_detail_4_texture" {
						texture = "gfx/interface/icons/generic_icons/maybe_icon.dds"
					}
				}
			}
		}

		### DETAIL ENTRY 5
		widget = {
			size = { 200 50 }

			block "interorg_detail_5_visibility" {
				visible = "no"
			}

			divider_clean = {
				parentanchor = bottom
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				spacing = 7

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 0 5 }

					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 16 }
						block "interorg_detail_5_name" {
							raw_text = "#todo interorg_detail_5_name#!"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
					}
					textbox = {
						layoutpolicy_horizontal = expanding
						size = { 0 20 }
						block "interorg_detail_5_content" {
							raw_text = "#todo interorg_detail_5_content#!"
						}
						align = right|nobaseline
						elide = right
						fontsize_min = 12
						using = fontsize_large
					}
				}

				icon = {
					size = { 35 35 }
					block "interorg_detail_5_texture" {
						texture = "gfx/interface/icons/generic_icons/maybe_icon.dds"
					}
				}
			}
		}
	}

	type com_organizations_panel_button = button_icon_round {
		size = { 50 50 }
		using = tooltip_above

		block "com_interorg_button_visible" {
			visible = "no"
		}
		blockoverride "icon" {
			texture = "gfx/interface/icons/notification_icons/journal.dds"
		}
		blockoverride "icon_size" {
			size = { 60% 60% }
		}

		onclick = "[GetVariableSystem.Set('com_open_window', 'com_international_organizations_sgui')]"
		tooltip = "com_gui_goto_international_orgs_panel"
	}

	type com_international_organization_reason = textbox {
		autoresize = yes
		block "interorg_reason_text" {
			text = "[JournalEntry.GetReason]"
		}
		min_width = 535
		max_width = 535
		multiline = yes
		using = default_list_position
		align = nobaseline
		margin = { 15 15 }

		background = {
			using = entry_bg
		}
	}

	type com_international_organization_buttons = flowcontainer {
		direction = vertical
		parentanchor = top|hcenter
		minimumsize = { 540 -1 }
		using = entry_bg_fancy
		spacing = 10
		margin_bottom = 20

		visible = "[Not( IsDataModelEmpty( JournalEntry.GetScriptedButtons ) )]"

		default_header_clean_faded = {
			parentanchor = hcenter
			blockoverride "text" {
				text = "com_gui_main_actions"
			}
			blockoverride "size" {
				size = { 532 45 }
			}
		}

		flowcontainer = {
			parentanchor = top|hcenter
			direction = vertical
			spacing = 5

			datamodel = "[JournalEntry.GetScriptedButtons]"

			item = {
				widget = {
					size = { 400 40 }
					com_international_organization_scripted_button = { }
				}
			}
		}
	}

	type com_international_organization_scripted_button = button {
		parentanchor = center
		using = default_button_action
		tooltip = "SCRIPTED_ACTION_TOOLTIP"
		enabled = "[IsValid( ScriptedButton.ExecuteEffect )]"
		onclick = "[Execute( ScriptedButton.ExecuteEffect )]"
		size = { 460 38 }
		margin = { 20 20 }

		widget = {
			visible = "[ScriptedButton.IsSelected]"
			size = { 100% 100% }

			background = {
				using = paper_bg
			}
		}

		textbox = {
			parentanchor = center
			align = nobaseline
			autoresize = yes
			max_width = 300
			elide = right
			fontsize_min = 14
			text = "[ScriptedButton.GetName]"
		}

		icon = {
			visible = "[ScriptedButton.IsSelected]"
			using = highlighted_square_selection
		}
	}

	type com_international_organization_members = flowcontainer {
		direction = vertical
		parentanchor = top|hcenter
		minimumsize = { 540 -1 }
		using = entry_bg_fancy
		spacing = 10
		margin_bottom = 20

		block "com_members_header" {
			default_header_clean_faded = {
				parentanchor = hcenter
				blockoverride "text" {
					text = "com_gui_members"
				}
				blockoverride "size" {
					size = { 532 45 }
				}
			}
		}

		flowcontainer = {
			direction = vertical
			using = default_list_position
			min_width = @panel_width_minus_30
			max_width = @panel_width_minus_30

			dynamicgridbox = {
				parentanchor = hcenter
				datamodel = "[JournalEntry.GetInvolvedCountries]"
				datamodel_wrap = 8
				flipdirection = yes

				item = {
					widget = {
						size = { 60 30 }

						small_flag = { }
					}
				}
			}
		}
	}

	type com_international_organization_modifiers = flowcontainer {
		visible = "[Not(IsDataModelEmpty(JournalEntry.GetTimedModifiers))]"
		direction = vertical
		parentanchor = top|hcenter
		minimumsize = { 540 -1 }
		using = entry_bg_fancy
		spacing = 10
		margin_bottom = 20

		default_header_clean_faded = {
			parentanchor = hcenter
			blockoverride "text" {
				text = "MODIFIERS"
			}
			blockoverride "size" {
				size = { 532 45 }
			}
		}

		flowcontainer = {
			datamodel = "[JournalEntry.GetTimedModifiers]"
			spacing = 5
			minimumsize = { 500 -1 }
			parentanchor = hcenter
			direction = vertical

			item = {
				container = {
					minimumsize = { 500 -1 }
					tooltip = "[TimedModifier.GetTooltip]"

					flowcontainer = {
						spacing = 10

						icon = {
							texture = "[TimedModifier.GetIcon]"
							size = { 25 25 }
						}

						textbox = {
							text = "[TimedModifier.GetName]"
							autoresize = yes
							align = nobaseline
							parentanchor = vcenter
						}
					}

					textbox = {
						text = "[TimedModifier.GetRemainingDuration]"
						autoresize = yes
