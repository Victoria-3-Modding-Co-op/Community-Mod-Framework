# INHERITED FROM BASE GAME
@panel_width_minus_30 = 510
@panel_width_minus_20 = 520
@panel_width_minus_10 = 530 # used to be 450
@panel_width = 540 # used to be 460
@panel_width_half = 270 # used to be 230
@panel_width_plus_10 = 550 # used to be 470
@panel_width_plus_14 = 554 # used to be 474
@panel_width_plus_14_half = 277 # used to be 237
@panel_width_plus_20 = 560 # used to be 480
@panel_width_plus_30 = 570 # used to be 490
@panel_width_plus_70 = 610 # used to be 530

####---------- INJECTABLE JOURNAL ENTRY WIDGETS ----------####
flowcontainer = {
	name = "widget_com_international_situation_factionless"
	ignoreinvisible = yes
	
	flowcontainer = {
		direction = vertical
		
		com_international_situation_header = {}
		com_international_situation_involved_countries = {}
		com_international_situation_phase_information = {}
	}
}

flowcontainer = {
	name = "widget_com_international_situation_two_faction"
	ignoreinvisible = yes
	
	flowcontainer = {
		direction = vertical
		spacing = 10
	}
}

flowcontainer = {
	name = "widget_com_international_situation_multi_faction"
	ignoreinvisible = yes
	
	flowcontainer = {
		direction = vertical
		spacing = 10
	}
}

####---------- INTERNATIONAL SITUATION GUI TYPES ----------####
types gbbf_journal_widget_types {
	type com_international_situation_header = flowcontainer {
		parentanchor = hcenter
		direction = vertical
		minimumsize = { 540 -1 }
		visible = "[JournalEntry.MakeScope.Var('com_situation_header_var').IsSet]"
		
		background = {
			using = dark_area
			alpha = 0.4
			margin = { 8 0 }
		}
		
		textbox = {
			parentanchor = hcenter
			size = { 100 40 }
			raw_text = "#bold [JournalEntry.MakeScope.Var('com_situation_header_var').GetFlagName]#!"
			align = hcenter|nobaseline
			using = fontsize_medium
			autoresize = yes
		}
	}
	
	type com_international_situation_involved_countries = flowcontainer {
		parentanchor = hcenter
		direction = vertical
		minimumsize = { 540 -1 }
		spacing = 20
		margin_bottom = 20
		
		#using = entry_bg_fancy
		
		widget = {
			parentanchor = hcenter
			size = { 220 30 }
			
			button = {
				parentanchor = center
				size = { 220 30 }
				position = { 0 10 }
				
				using = default_button_primary_action
				using = confirm_button_sound
				text = "com_situation_toggle_involved"
				onclick = "[GetVariableSystem.Toggle('com_show_involved_countries')]"
			}
		}
		
		flowcontainer = {
			parentanchor = hcenter
			direction = vertical
			min_width = @panel_width_minus_30
			max_width = @panel_width_minus_30
			spacing = 10
			
			visible = "[GetVariableSystem.Exists('com_show_involved_countries')]"
			
			background = {
				using = entry_bg_simple
			}
			
			textbox = {
				parentanchor = hcenter
				autoresize = yes
				text = "com_situation_involved_countries"
				align = center|nobaseline
				elide = right
				using = fontsize_large
			}
			
			divider_decorative = {
				parentanchor = hcenter
			}
			
			dynamicgridbox = {
				parentanchor = hcenter
				datamodel = "[JournalEntry.GetInvolvedCountries]"
				datamodel_wrap = 8
				flipdirection = yes
				
				item = {
					widget = {
						size = { 60 40 }
						small_flag = { }
					}
				}
			}
		}
		
		flowcontainer = {
			parentanchor = hcenter
			direction = vertical
			using = default_list_position
			min_width = @panel_width_minus_30
			max_width = @panel_width_minus_30
			margin = { 5 10 }
			spacing = 10
			
			visible = "[Not(IsDataModelEmpty(JournalEntry.MakeScope.GetList('com_situation_interloper_list')))]"
			
			background = {
				using = entry_bg_simple
			}
			
			textbox = {
				parentanchor = hcenter
				autoresize = yes
				text = "com_situation_interloper_countries"
				align = center|nobaseline
				elide = right
				using = fontsize_large
			}
			
			divider_decorative = {
				parentanchor = hcenter
			}
			
			dynamicgridbox = {
				parentanchor = hcenter
				datamodel = "[JournalEntry.MakeScope.GetList('com_situation_interloper_list')]"
				datamodel_wrap = 8
				flipdirection = yes
				
				item = {
					widget = {
						datacontext = "[Scope.GetCountry]"
						size = { 60 40 }
						small_flag = { }
					}
				}
			}
		}
	}
	
	type com_international_situation_phase_information = flowcontainer {
		direction = vertical
		parentanchor = hcenter
		minimumsize = { 540 -1 }
		
		visible = "[And(
			JournalEntry.MakeScope.Var('com_situation_phase_icon_var').IsSet,
			JournalEntry.MakeScope.Var('com_situation_phase_name_var').IsSet
		)]"
		
		widget = {
			parentanchor = center
			size = { 540 100 }
			
			background = {
				using = default_header_bg
				margin = { 8 0 }
			}
			
			icon = {
				parentanchor = center
				position = { -138 0 }
				size = { 290 100 }
				texture = "gfx/interface/backgrounds/bg_bronze_with_frame_horizontal_right.dds"
				framesize = { 20 200 }
				frame = 2
			}
			
			icon = {
				parentanchor = left|vcenter
				size = { 180 210 }
				scale = 0.75
				texture = "gfx/interface/politics_view/institution_current_level.dds"
				
				textbox = {
					parentanchor = center
					size = { 100 100 }
					fontsize = 80
					align = vcenter|hcenter
					text = "com_situation_phase_icon"
				}
			}
			
			textbox = {
				parentanchor = center
				size = { 100 100 }
				position = { 0 0 }
				align = hcenter|nobaseline
				text = "com_situation_current_phase"
				using = fontsize_large
			}
			textbox = {
				parentanchor = center
				size = { 100 100 }
				position = { 0 0 }
				align = vcenter|hcenter
				text = "com_situation_current_phase_name"
				using = fontsize_xl
			}
			
			textbox = {
				parentanchor = right|vcenter
				size = { 100 100 }
				position = { 0 0 }
				align = vcenter|hcenter
				text = "com_situation_phase_effects"
				using = fontsize_xl
			}
		}
	}
	
	type com_international_situation_outcomes = flowcontainer {
		direction = vertical
		parentanchor = center
		size = { 540 100 }
		
		button = {
			parentanchor = center
			using = default_button_primary_action
			using = confirm_button_sound
			size = { 220 30 }
			text = "com_view_situation_endings"
			onclick = "[GetVariableSystem.Toggle('com_show_situation_outomes')]"
		}
		
		
	}
	
	type com_international_situation_factors = flowcontainer {
		direction = vertical
		parentanchor = center
		size = { 540 100 }
		
	}
}